# ==============================================================================
# DKE Smart Sales - Backend Environment Configuration
# ==============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL Database
# ------------------------------------------------------------------------------
POSTGRES_DB=odoo
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo

# Port PostgreSQL yang di-expose ke host (default: 5434 agar tidak bentrok)
DB_PORT=5434

# ------------------------------------------------------------------------------
# Odoo Server
# ------------------------------------------------------------------------------
# Port Odoo yang di-expose ke host
ODOO_PORT=8069
