<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sale Transaction Tree View -->
    <record id="dke_sale_transaction_view_tree" model="ir.ui.view">
        <field name="name">dke.sale.transaction.tree</field>
        <field name="model">dke.sale.transaction</field>
        <field name="arch" type="xml">
            <tree string="Marketplace Transactions"
                  decoration-warning="state == 'processing'"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'cancelled'">
                <field name="name"/>
                <field name="external_order_id"/>
                <field name="customer_name"/>
                <field name="order_date"/>
                <field name="amount_gross"/>
                <field name="amount_net"/>
                <field name="marketplace"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Sale Transaction Form View -->
    <record id="dke_sale_transaction_view_form" model="ir.ui.view">
        <field name="name">dke.sale.transaction.form</field>
        <field name="model">dke.sale.transaction</field>
        <field name="arch" type="xml">
            <form string="Marketplace Transaction">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,processing,delivery,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Order Info">
                            <field name="external_order_id"/>
                            <field name="marketplace"/>
                            <field name="order_date"/>
                            <field name="delivery_date"/>
                            <field name="integration_id"/>
                        </group>
                        <group string="Customer">
                            <field name="customer_id"/>
                            <field name="customer_name"/>
                            <field name="customer_phone"/>
                            <field name="shipping_address"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="product_name"/>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="subtotal"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Financial Summary">
                            <group>
                                <field name="amount_gross"/>
                                <field name="marketplace_fee"/>
                                <field name="shipping_subsidy"/>
                                <field name="amount_net"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sale Transaction Search View -->
    <record id="dke_sale_transaction_view_search" model="ir.ui.view">
        <field name="name">dke.sale.transaction.search</field>
        <field name="model">dke.sale.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Transactions">
                <field name="name"/>
                <field name="external_order_id"/>
                <field name="customer_name"/>
                <filter name="done" string="Completed" domain="[('state', '=', 'done')]"/>
                <filter name="processing" string="Processing" domain="[('state', '=', 'processing')]"/>
                <group string="Group By">
                    <filter name="group_marketplace" string="Marketplace" context="{'group_by': 'marketplace'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_date" string="Order Date" context="{'group_by': 'order_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Sale Transaction Action -->
    <record id="action_dke_sale_transaction" model="ir.actions.act_window">
        <field name="name">Marketplace Transactions</field>
        <field name="res_model">dke.sale.transaction</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="dke_sale_transaction_view_search"/>
    </record>

</odoo>
