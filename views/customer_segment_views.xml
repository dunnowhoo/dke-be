<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Customer Segment Tree View -->
    <record id="dke_customer_segment_view_tree" model="ir.ui.view">
        <field name="name">dke.customer.segment.tree</field>
        <field name="model">dke.customer.segment</field>
        <field name="arch" type="xml">
            <tree string="Customer Segments">
                <field name="name"/>
                <field name="matched_count"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Customer Segment Form View -->
    <record id="dke_customer_segment_view_form" model="ir.ui.view">
        <field name="name">dke.customer.segment.form</field>
        <field name="model">dke.customer.segment</field>
        <field name="arch" type="xml">
            <form string="Customer Segment">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="matched_count"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Rules (JSON)">
                            <field name="rules_json" nolabel="1"
                                   placeholder='[{"field": "total_spent", "operator": ">=", "value": 1000000}]'/>
                        </page>
                        <page string="Preview Customers">
                            <field name="preview_partner_ids"/>
                        </page>
                        <page string="Campaigns">
                            <field name="campaign_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Customer Segment Action -->
    <record id="action_dke_customer_segment" model="ir.actions.act_window">
        <field name="name">Customer Segments</field>
        <field name="res_model">dke.customer.segment</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
